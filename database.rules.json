{
  "rules": {
    "rooms": {
      "$pin": {
        ".read": "auth != null && $pin.matches(/^[0-9]{8}$/)",
        ".write": "auth != null && $pin.matches(/^[0-9]{8}$/)",

        "meta": {
          ".validate": "newData.hasChildren(['createdAt', 'commanderId'])",

          "createdAt": {
            ".validate": "newData.isNumber()"
          },
          "commanderId": {
            ".validate": "newData.isString() && newData.val().length <= 64"
          },
          "targetLandingAt": {
            ".validate": "newData.isNumber() || newData.val() == null"
          },
          "locked": {
            ".validate": "newData.isBoolean() || newData.val() == null"
          },
          "targetLabel": {
            ".validate": "newData.isString() && newData.val().length <= 40 || newData.val() == null"
          },
          "targetX": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 9999 || newData.val() == null"
          },
          "targetY": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 9999 || newData.val() == null"
          },
          "lastActivityAt": {
            ".validate": "newData.isNumber()"
          },
          "wavePresets": {
            "$presetId": {
              ".validate": "newData.hasChildren(['id'])",
              "id": { ".validate": "newData.isString() && newData.val().length <= 40" },
              "name": { ".validate": "newData.isString() && newData.val().length <= 40 || newData.val() == null" },
              "targetLandingAt": { ".validate": "newData.isNumber() || newData.val() == null" },
              "targetLabel": { ".validate": "newData.isString() && newData.val().length <= 40 || newData.val() == null" },
              "targetX": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 9999 || newData.val() == null" },
              "targetY": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 9999 || newData.val() == null" },
              "$other": { ".validate": false }
            }
          },
          "wavePresetOrder": {
            ".validate": "newData.hasChildren() || !newData.exists()"
          },
          "battles": {
            "$battleId": {
              ".validate": "newData.hasChildren(['id', 'lockedAt']) || !newData.exists()"
            }
          },
          "battleOrder": {
            ".validate": "newData.hasChildren() || !newData.exists()"
          },
          "$other": { ".validate": false }
        },

        "members": {
          "$uid": {
            ".write": "auth != null && (auth.uid === $uid || root.child('rooms').child($pin).child('meta').child('commanderId').val() === auth.uid)",
            ".validate": "newData.hasChildren(['name']) || !newData.exists()",

            "name": {
              ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 20"
            },
            "role": {
              ".validate": "newData.val() == 'commander' || newData.val() == 'driver' || newData.val() == null"
            },
            "isSuicide": {
              ".validate": "newData.isBoolean() || newData.val() == null"
            },
            "marchSeconds": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 600 || newData.val() == null"
            },
            "status": {
              ".validate": "newData.val() == 'ready' || newData.val() == 'adjusting' || newData.val() == 'offline' || newData.val() == null"
            },
            "lastSeen": {
              ".validate": "newData.isNumber() || newData.val() == null"
            },
            "rallying": {
              ".validate": "newData.isBoolean() || newData.val() == null"
            },
            "rallyWindowSeconds": {
              ".validate": "newData.isNumber() && (newData.val() == 300 || newData.val() == 600) || newData.val() == null"
            },
            "landingOffsetSeconds": {
              ".validate": "newData.isNumber() && newData.val() >= -60 && newData.val() <= 60 || newData.val() == null"
            },
            "participantType": {
              ".validate": "newData.val() == 'driver' || newData.val() == 'passenger' || newData.val() == null"
            },
            "counterRally": {
              ".validate": "newData.isBoolean() || newData.val() == null"
            },
            "$other": { ".validate": false }
          }
        },

        "$other": { ".validate": false }
      }
    }
  }
}
